  "keyFeatures": [
    "W3C WebDriver protocol compliance with Android-specific extensions",
    "Supports native, hybrid, and mobile web app automation",
    "Rich element location strategies including UiAutomator selectors, XPath, and accessibility IDs",
    "Mobile gesture automation (swipe, pinch, fling, scroll, drag)",
    "Parallel test execution support for real devices and emulators",
    "BiDi protocol support for log streaming and context events",
    "MJPEG screen streaming for real-time device screenshots",
    "App management commands (install, uninstall, permissions, activities)",
    "Multi-window and multi-display testing support",
    "Emulator control (sensor emulation, console commands, camera injection)"
  ],
